DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="change-me-in-production"
APP_URL="http://localhost:3200"

# --- Notifications ---
# inbox = store in-app only | smtp = send real email when SMTP_* set
SMTP_MODE="inbox"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MedCare <noreply@yourdomain.com>"

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
LINE_MESSAGING_TOKEN=

# --- OAuth (enable by filling keys; UI shows providers when enabled) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# --- AI Medical Consultant ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Telemedicine video ---
# VIDEO_PROVIDER=mock|daily|agora
VIDEO_PROVIDER=mock
DAILY_API_KEY=
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# --- File storage (optional; otherwise use public image URLs) ---
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
