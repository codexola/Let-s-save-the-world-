generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  DEVELOPER
  ADMIN
  PATIENT
  DOCTOR
  NURSE
  HOSPITAL
  PHARMACY
  COMPANY
  CAREGIVER
  RESEARCHER
}

enum SubscriptionPlan {
  INDIVIDUAL
  PREMIUM_FEATURES
  CORPORATE
  CORPORATE_PREMIUM
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
  ADMIN_GRANTED
}

enum PrescriptionStatus {
  ISSUED
  APPROVED
  PREPARING
  READY
  DELIVERED
  EXPIRED
}

enum AppointmentType {
  VIDEO
  IN_PERSON
  HOME_VISIT
}

enum AppointmentStatus {
  BOOKED
  CANCELLED
  RESCHEDULED
  COMPLETED
  WAITING_LIST
  NO_SHOW
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?
  name             String
  role             Role      @default(PATIENT)
  phone            String?
  photoUrl         String?
  bio              String?
  locale           String    @default("ja")
  gender           String?
  dateOfBirth      DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  phoneVerified    Boolean   @default(false)
  verified         Boolean   @default(false)
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  permissions         UserPermission[]
  patientProfile      PatientProfile?
  doctorProfile       DoctorProfile?
  nurseProfile        NurseProfile?
  hospitalProfile     HospitalProfile?
  pharmacyProfile     PharmacyProfile?
  companyProfile      CompanyProfile?
  subscriptions       Subscription[]
  registrationCodes   RegistrationCode[] @relation("CodeOwner")
  usedCodes           RegistrationCode[] @relation("CodeUser")
  appointments        Appointment[]      @relation("PatientAppointments")
  doctorAppointments  Appointment[]      @relation("DoctorAppointments")
  prescriptions       Prescription[]     @relation("PatientPrescriptions")
  issuedPrescriptions Prescription[]     @relation("DoctorPrescriptions")
  notifications       Notification[]
  reviews             Review[]
  blogPosts           BlogPost[]
  blogViews           BlogView[]
  blogComments        BlogComment[]
  chatMessages        ChatMessage[]
  chatThreadsA        ChatThread[]       @relation("ThreadParticipantA")
  chatThreadsB        ChatThread[]       @relation("ThreadParticipantB")
  supportTickets      SupportTicket[]
  contactRequests     ContactRequest[]
  platformReviews     PlatformReview[]
  auditLogs           AuditLog[]
  consents            Consent[]
  familyMembers       FamilyMember[]     @relation("FamilyOwner")
  ehr                 ElectronicHealthRecord?
  aiConsultations            AiConsultation[]
  featureOverrides           FeatureOverride[]
  telemedicineSessionsHost   TelemedicineSession[] @relation("TelemedicineHost")
  telemedicineSessionsPatient TelemedicineSession[] @relation("TelemedicinePatient")
  communityPosts             CommunityPost[]
  invoices                   Invoice[]
  oauthAccounts              OAuthAccount[]
  webAuthnCredentials        WebAuthnCredential[]
  identityVerifications      IdentityVerification[]
  followUpReminders          FollowUpReminder[]
  hospitalConfirmationsGiven DoctorProfile[] @relation("HospitalConfirmer")
  blogBookmarks              BlogBookmark[]
  blogLikes                  BlogLike[]
  marketplaceOrders          MarketplaceOrder[]
  healthMetrics              HealthMetric[]
  notificationPreference     NotificationPreference?
  pushDevices                PushDevice[]
  complaints                 Complaint[]
  accessLogs                 AccessLog[]
  dataSubjectRequests        DataSubjectRequest[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String
  users       UserPermission[]
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  enabled      Boolean    @default(true)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model FeatureFlag {
  id          String            @id @default(cuid())
  key         String            @unique
  name        String
  description String
  enabled     Boolean           @default(true)
  category    String
  overrides   FeatureOverride[]
}

model FeatureOverride {
  id        String      @id @default(cuid())
  userId    String
  featureId String
  enabled   Boolean
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   FeatureFlag @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([userId, featureId])
}

model Archive {
  id          String   @id @default(cuid())
  name        String
  description String?
  payload     String
  version     Int      @default(1)
  initialized Boolean  @default(false)
  createdById String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PatientProfile {
  id                    String  @id @default(cuid())
  userId                String  @unique
  bloodType             String?
  allergies             String?
  medications           String?
  medicalHistory        String?
  insuranceInfo         String?
  familyDoctor          String?
  emergencyContact      String?
  favoriteHospitals     String?
  favoriteDoctors       String?
  paymentMethods        String?
  incomeBracket         String?
  preferredLanguage     String?
  governmentId          String?
  governmentIdType      String?
  governmentIdDocument  String?
  governmentIdVerified  Boolean @default(false)
  faceImageUrl          String?
  faceVerified          Boolean @default(false)
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id                  String  @id @default(cuid())
  userId              String  @unique
  licenseNumber       String?
  nationalRegNumber   String?
  university          String?
  graduationYear      Int?
  boardCertifications String?
  specialty           String?
  subspecialty        String?
  clinicalExperience  String?
  yearsExperience     Int?
  treatmentMethods    String?
  successRate         Float?
  hospitalAffiliation String?
  languages           String?
  awards              String?
  publications        String?
  research            String?
  consultationFee     Int?
  schedule            String?
  onlineAvailable       Boolean @default(true)
  offlineAvailable      Boolean @default(true)
  verified              Boolean @default(false)
  licenseVerified       Boolean @default(false)
  govDbVerified         Boolean @default(false)
  hospitalConfirmed     Boolean @default(false)
  hospitalConfirmedById String?
  licenseDocumentUrl    String?
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospitalConfirmer     User?   @relation("HospitalConfirmer", fields: [hospitalConfirmedById], references: [id])
}

model NurseProfile {
  id                  String  @id @default(cuid())
  userId              String  @unique
  licenseNumber       String?
  nationalRegNumber   String?
  university          String?
  graduationYear      Int?
  boardCertifications String?
  specialty           String?
  subspecialty        String?
  clinicalExperience  String?
  yearsExperience     Int?
  treatmentMethods    String?
  successRate         Float?
  hospitalAffiliation String?
  languages           String?
  awards              String?
  publications        String?
  research            String?
  consultationFee     Int?
  schedule            String?
  certifications      String?
  clinicalSpecialties String?
  shiftAvailability   String?
  homeVisitAvailable  Boolean @default(false)
  onlineAvailable     Boolean @default(true)
  offlineAvailable    Boolean @default(true)
  verified            Boolean @default(false)
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HospitalProfile {
  id                         String  @id @default(cuid())
  userId                     String  @unique
  name                       String
  departments                String?
  equipment                  String?
  operatingHours             String?
  emergencyAvailable         Boolean @default(false)
  icuBeds                    Int     @default(0)
  totalBeds                  Int     @default(0)
  operatingRooms             Int     @default(0)
  parking                    Boolean @default(false)
  acceptedInsurance          String?
  languages                  String?
  pharmacyOnSite             Boolean @default(false)
  ambulance                  Boolean @default(false)
  accreditation              String?
  businessRegistration       String?
  medicalInstitutionReg      String?
  businessRegVerified        Boolean @default(false)
  medicalInstitutionVerified Boolean @default(false)
  treatmentMethods           String?
  address                    String?
  latitude                   Float?
  longitude                  Float?
  doctorsList                String?
  nursesList                 String?
  verified                   Boolean @default(false)
  user                       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PharmacyProfile {
  id                  String     @id @default(cuid())
  userId              String     @unique
  name                String
  deliveryAvailable   Boolean    @default(true)
  pickupAvailable     Boolean    @default(true)
  prescriptionSupport Boolean    @default(true)
  discounts           String?
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicines           Medicine[]
}

model CompanyProfile {
  id                   String  @id @default(cuid())
  userId               String  @unique
  name                 String
  taxId                String?
  businessRegistration String?
  businessRegVerified  Boolean @default(false)
  taxIdVerified        Boolean @default(false)
  employeeCount        Int     @default(0)
  employeesJson        String?
  healthCheckSchedule  String?
  medicalReports       String?
  healthCampaigns      String?
  vaccinationPrograms  String?
  insuranceSupport     String?
  verified             Boolean @default(false)
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  employees            CorporateEmployee[]
  campaigns            CorporateCampaign[]
  certificates         MedicalCertificate[]
  sickLeaves           SickLeaveRecord[]
}


model Subscription {
  id               String             @id @default(cuid())
  userId           String
  plan             SubscriptionPlan
  status           SubscriptionStatus @default(PENDING)
  priceYen         Int
  paid             Boolean            @default(false)
  adminGranted     Boolean            @default(false)
  grantedById      String?
  startsAt         DateTime?
  endsAt           DateTime?
  paymentRef       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  registrationCode RegistrationCode?
  paymentHistory   PaymentHistory[]
}

model RegistrationCode {
  id             String        @id @default(cuid())
  code           String        @unique
  email          String
  subscriptionId String?       @unique
  ownerId        String?
  usedById       String?
  used           Boolean       @default(false)
  expiresAt      DateTime
  createdAt      DateTime      @default(now())
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  owner          User?         @relation("CodeOwner", fields: [ownerId], references: [id])
  usedBy         User?         @relation("CodeUser", fields: [usedById], references: [id])
}

model PaymentHistory {
  id             String       @id @default(cuid())
  subscriptionId String
  amountYen      Int
  method         String
  status         String
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  channel   String   @default("email")
  kind      String   @default("general")
  subject   String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Appointment {
  id                   String            @id @default(cuid())
  patientId            String
  doctorId             String?
  hospitalId           String?
  type                 AppointmentType
  status               AppointmentStatus @default(BOOKED)
  scheduledAt          DateTime
  notes                String?
  recurrenceRule       String?
  recurrenceParentId   String?
  queuePosition        Int?
  estimatedWaitMinutes Int?
  createdAt            DateTime          @default(now())
  patient              User              @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor               User?             @relation("DoctorAppointments", fields: [doctorId], references: [id])
}

model Prescription {
  id         String             @id @default(cuid())
  patientId  String
  doctorId   String
  pharmacyId String?
  medication String
  dosage     String?
  status     PrescriptionStatus @default(ISSUED)
  issuedAt   DateTime           @default(now())
  expiresAt  DateTime?
  patient    User               @relation("PatientPrescriptions", fields: [patientId], references: [id])
  doctor     User               @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
}

model Medicine {
  id           String          @id @default(cuid())
  pharmacyId   String
  name         String
  manufacturer String?
  ingredients  String?
  interactions String?
  warnings     String?
  alternatives String?
  imageUrl     String?
  priceYen     Int
  stock        Int             @default(0)
  pharmacy     PharmacyProfile @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountPercent Int       @default(0)
  discountYen     Int       @default(0)
  ambassadorOnly  Boolean   @default(false)
  active          Boolean   @default(true)
  maxUses         Int?
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
}

model BlogBookmark {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model BlogLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model CorporateEmployee {
  id             String    @id @default(cuid())
  companyId      String
  name           String
  email          String
  department     String?
  status         String    @default("active")
  userId         String?
  lastCheckupAt  DateTime?
  vaccinatedAt   DateTime?
  createdAt      DateTime  @default(now())
  company        CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
}

model CorporateCampaign {
  id               String   @id @default(cuid())
  companyId        String
  name             String
  type             String   @default("health")
  status           String   @default("planned")
  participation    Int      @default(0)
  targetCount      Int      @default(0)
  scheduledAt      DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  company          CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model MedicalCertificate {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String?
  employeeName String
  type        String   @default("fitness")
  issuedAt    DateTime @default(now())
  validUntil  DateTime?
  notes       String?
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model SickLeaveRecord {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String?
  employeeName String
  startDate    DateTime
  endDate      DateTime?
  reason       String?
  status       String   @default("open")
  createdAt    DateTime @default(now())
  company      CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model MarketplaceOrder {
  id           String   @id @default(cuid())
  userId       String
  medicineId   String
  quantity     Int
  totalYen     Int
  delivery     Boolean  @default(false)
  status       String   @default("placed")
  couponCode   String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TelemedicineSession {
  id                  String   @id @default(cuid())
  appointmentId       String?
  hostId              String
  patientId           String
  roomUrl             String
  provider            String   @default("mock")
  status              String   @default("scheduled")
  notes               String?
  recordingConsent    Boolean  @default(false)
  recordingEnabled    Boolean  @default(false)
  recordingUrl        String?
  screenShareEnabled  Boolean  @default(true)
  quality             String   @default("hd")
  transcription       String?
  createdAt           DateTime @default(now())
  host                User     @relation("TelemedicineHost", fields: [hostId], references: [id])
  patient             User     @relation("TelemedicinePatient", fields: [patientId], references: [id])
}

model CommunityPost {
  id        String   @id @default(cuid())
  authorId  String
  title     String
  body      String
  topic     String?
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String    @id @default(cuid())
  userId      String
  amountYen   Int
  description String
  status      String    @default("OPEN")
  providerRef String?
  paymentMethod String?
  couponCode  String?
  discountYen Int       @default(0)
  refundedYen Int       @default(0)
  corporate   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  paidAt      DateTime?
  refundedAt  DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(cuid())
  authorId   String
  targetType String
  targetId   String
  rating     Int
  comment    String?
  verified   Boolean  @default(false)
  fraudScore Int      @default(0)
  spamFlag   Boolean  @default(false)
  createdAt  DateTime @default(now())
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id         String        @id @default(cuid())
  authorId   String
  title      String
  content    String
  coverImage String
  tags       String?
  category   String?       @default("medical_news")
  published  Boolean       @default(false)
  viewCount  Int           @default(0)
  likeCount  Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views      BlogView[]
  comments   BlogComment[]
  bookmarks  BlogBookmark[]
  likes      BlogLike[]
}

model BlogView {
  id        String   @id @default(cuid())
  postId    String
  viewerId  String
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  viewer    User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([postId, viewerId])
}

model BlogComment {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  body      String
  parentId  String?
  rating    Int?
  createdAt DateTime      @default(now())
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("CommentReplies")
}

model ChatThread {
  id             String        @id @default(cuid())
  participantAId String
  participantBId String
  pairType       String?
  agreedByA      Boolean       @default(false)
  agreedByB      Boolean       @default(false)
  encrypted      Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  participantA   User          @relation("ThreadParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB   User          @relation("ThreadParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]

  @@unique([participantAId, participantBId])
}

model ChatMessage {
  id               String     @id @default(cuid())
  threadId         String
  senderId         String
  body             String
  encrypted        Boolean    @default(true)
  attachment       String?
  attachmentType   String?
  attachmentName   String?
  prescriptionId   String?
  createdAt        DateTime   @default(now())
  thread           ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender           User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model ContactRequest {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String
  body      String
  target    String   @default("admin")
  status    String   @default("open")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  email       String
  subject     String
  body        String
  status      String   @default("open")
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PlatformReview {
  id        String   @id @default(cuid())
  authorId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model AiConsultation {
  id                     String    @id @default(cuid())
  userId                 String
  symptoms               String
  analysis               String
  riskLevel              String
  specialty              String?
  recommendations        String?
  emergency              Boolean   @default(false)
  diseasePredictions     String?
  medications            String?
  lifestyleAdvice        String?
  nutritionAdvice        String?
  mentalHealthAdvice     String?
  recommendedHospitals   String?
  recommendedDoctors     String?
  recommendedNurses      String?
  nearbyProviders        String?
  appointmentSuggestion  String?
  resultJson             String?
  followUpAt             DateTime?
  createdAt              DateTime  @default(now())
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  followUpReminders      FollowUpReminder[]
}

model OAuthAccount {
  id              String   @id @default(cuid())
  userId          String
  provider        String
  providerSubject String
  email           String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique
  publicKey    String
  counter      Int      @default(0)
  deviceType   String?
  transports   String?
  nickname     String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  userId    String?
  purpose   String   @default("phone_verify")
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model IdentityVerification {
  id           String    @id @default(cuid())
  userId       String
  roleType     String
  type         String
  status       String    @default("pending")
  documentUrl  String?
  documentData String?
  notes        String?
  verifiedAt   DateTime?
  reviewedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FollowUpReminder {
  id             String         @id @default(cuid())
  userId         String
  consultationId String?
  title          String
  body           String
  dueAt          DateTime
  completed      Boolean        @default(false)
  notified       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultation   AiConsultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)
}

model AuthChallenge {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  challenge String
  payload   String?
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ElectronicHealthRecord {
  id            String   @id @default(cuid())
  userId        String   @unique
  diagnoses     String?
  treatments    String?
  operations    String?
  labResults    String?
  imaging       String?
  vaccinations  String?
  familyHistory String?
  lifestyle     String?
  genetics      String?
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FamilyMember {
  id           String    @id @default(cuid())
  ownerId      String
  name         String
  relationship String
  dateOfBirth  DateTime?
  owner        User      @relation("FamilyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
}

model Consent {
  id          String    @id @default(cuid())
  userId      String
  type        String
  purpose     String?
  legalBasis  String    @default("consent")
  granted     Boolean
  version     String
  locale      String    @default("ja")
  ip          String?
  withdrawnAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model AccessLog {
  id         String   @id @default(cuid())
  userId     String?
  accessorId String?
  action     String
  resource   String
  resourceId String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([resource, createdAt])
}

model RetentionPolicy {
  id          String   @id @default(cuid())
  resource    String   @unique
  retainDays  Int
  action      String   @default("anonymize")
  description String?
  active      Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model DataSubjectRequest {
  id          String    @id @default(cuid())
  userId      String
  type        String
  status      String    @default("open")
  details     String?
  resolution  String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  details   String?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model EmergencyRequest {
  id               String   @id @default(cuid())
  patientId        String?
  symptoms         String
  location         String?
  status           String   @default("requested")
  etaMinutes       Int?
  hospitalNotified Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model LaboratoryOrder {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String?
  testType  String
  status    String   @default("ordered")
  result    String?
  createdAt DateTime @default(now())
}

model ClinicalTrial {
  id           String   @id @default(cuid())
  title        String
  eligibility  String?
  compensation String?
  location     String?
  status       String   @default("recruiting")
  createdAt    DateTime @default(now())
}

model KnowledgeItem {
  id          String   @id @default(cuid())
  type        String
  title       String
  summary     String?
  body        String
  mediaUrl    String?
  tags        String?
  category    String?
  published   Boolean  @default(true)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DrugMonograph {
  id           String   @id @default(cuid())
  name         String
  manufacturer String?
  ingredients  String?
  uses         String?
  dosage       String?
  interactions String?
  warnings     String?
  sideEffects  String?
  category     String?
  createdAt    DateTime @default(now())
}

model HealthMetric {
  id         String   @id @default(cuid())
  userId     String
  type       String
  value      Float
  unit       String?
  note       String?
  recordedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, recordedAt])
}

model NotificationPreference {
  id                   String  @id @default(cuid())
  userId               String  @unique
  emailEnabled         Boolean @default(true)
  smsEnabled           Boolean @default(true)
  pushEnabled          Boolean @default(true)
  lineEnabled          Boolean @default(true)
  appointmentReminders Boolean @default(true)
  prescriptionReminders Boolean @default(true)
  subscriptionReminders Boolean @default(true)
  emergencyAlerts      Boolean @default(true)
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushDevice {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String   @default("web")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
}

model Complaint {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  email       String
  subject     String
  body        String
  againstType String?
  againstId   String?
  status      String   @default("open")
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SecurityEvent {
  id        String   @id @default(cuid())
  type      String
  severity  String   @default("info")
  ip        String?
  path      String?
  userId    String?
  details   String?
  createdAt DateTime @default(now())
}

model BackupRecord {
  id         String   @id @default(cuid())
  filename   String
  sizeBytes  Int      @default(0)
  status     String   @default("completed")
  notes      String?
  createdBy  String?
  createdAt  DateTime @default(now())
}
